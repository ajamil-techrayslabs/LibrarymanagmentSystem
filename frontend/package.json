
{
  "dependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "scripts": {
    "tailwind": "npx @tailwindcss/cli -i ./src/styles/input.css -o ./dist/output.css --watch",
    "ts": "npx tsc -w",
    "build": "npm run build:css && npm run build:ts",
    "build:css": "npx @tailwindcss/cli -i ./src/styles/input.css -o ./dist/output.css --minify",
    "build:ts": "npx tsc"
  }
}
